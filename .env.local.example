# ─────────────────────────────────────────────
# ProAfiliados — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — NEVER expose on the frontend. Used only in server routes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Evolution API (WhatsApp) ──────────────────
# URL of your self-hosted Evolution API instance (no trailing slash, no /v2)
# Example (Railway): https://evolution-api-production-xxxx.up.railway.app
EVOLUTION_API_URL=https://your-evolution-api.example.com
# The global API key defined in Evolution API env var AUTHENTICATION_API_KEY
EVOLUTION_API_KEY=your-evolution-api-key

# ── Webhook ───────────────────────────────────
# A random secret used to verify incoming webhook calls from Evolution API.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-random-secret-here

# ── App URL ───────────────────────────────────
# Full public URL of your app (used to register the webhook URL with Evolution API)
# In production this is your Vercel deployment URL or custom domain.
# On Vercel, VERCEL_URL is auto-set but lacks the https:// prefix, so set this manually.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Mercado Pago (Payments) ───────────────────
# Get from: https://www.mercadopago.com.br/developers → Your app → Credentials
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
